# Restaurant Reservation System - Environment Variables

# Database
DATABASE_URL=sqlite:///./restaurant_reservations.db
# Production: postgresql://user:pass@localhost/restaurant_ai

# Twilio SMS & Phone Numbers (Required for SMS and phone number management)
# Get credentials from: https://www.twilio.com/console
# Note: Each restaurant sets their own phone number in Settings (stored in database)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Retell AI (Required for voice AI processing)
# Retell handles all voice processing (ASR, LLM, TTS) - simplifies integration
# Get your API key from: https://retellai.com/
RETELL_API_KEY=your_retell_api_key_here

# LLM Provider - Gemini is default, OpenAI is fallback (Used for SMS conversations)
# Primary: Gemini (default, cheaper)
# Get your API key from: https://aistudio.google.com/
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp
LLM_PROVIDER=gemini

# Fallback: OpenAI (optional, used if Gemini fails for SMS)
# Get your API key from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Stripe Payments (Optional)
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google Maps (Optional - for importing operating hours from Google Maps)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Server Configuration
PORT=8000
PUBLIC_URL=https://your-domain.com
CORS_ORIGINS=http://localhost:4173,http://localhost:5173,http://192.168.1.100:4173,http://192.168.1.100:5173

# Environment
ENVIRONMENT=development

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here
